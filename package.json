{
  "name": "better-spa",
  "private": true,
  "type": "module",
  "description": "A minimal shell SPA boilerplate with SSR shell for auth and client-side SPA for everything else",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "node --env-file=.env .output/server/index.mjs",
    "start": "node .output/server/index.mjs",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check-types": "tsc --noEmit",
    "check": "pnpm format && pnpm lint && pnpm check-types",
    "kysely": "kysely",
    "deps": "pnpx taze@latest -Ilw",
    "deps:major": "pnpx taze@latest major -Ilw",
    "ui": "pnpx shadcn@latest",
    "auth:secret": "pnpx @better-auth/cli@latest secret",
    "auth:generate": "pnpx @better-auth/cli@latest generate --config ./src/lib/auth/auth.ts"
  },
  "dependencies": {
    "@better-upload/client": "^3.0.19",
    "@better-upload/server": "^3.0.19",
    "@daveyplate/better-auth-ui": "^3.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@orpc/client": "^1.14.2",
    "@orpc/server": "^1.14.2",
    "@orpc/tanstack-query": "^1.14.2",
    "@t3-oss/env-core": "^0.13.11",
    "@tanem/react-nprogress": "^6.0.3",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.65",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/start-server-core": "^1.167.30",
    "@vitejs/plugin-react": "^6.0.1",
    "better-auth": "^1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "kysely": "^0.28.17",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "nitro": "3.0.1-alpha.2",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "react-resizable-panels": "^4.11.0",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "uuidv7": "^1.2.1",
    "vaul": "^1.1.2",
    "vite": "^8.0.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@biomejs/biome": "^2.4.15",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.20.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
