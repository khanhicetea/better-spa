# =============================================================================
# Required to start the app
# =============================================================================

VITE_BASE_URL=http://localhost:3000

# Postgres connection string. Use docker-compose.yml at the repo root for a
# local Postgres 16 instance: `docker compose up -d`.
DATABASE_URL="postgresql://user:password@localhost:5432/postgres"

# Generate with: pnpm auth:secret
BETTER_AUTH_SECRET=

# =============================================================================
# Optional: runtime / hosting
# =============================================================================

# Nitro deployment preset. Leave unset for the default Node server.
# Allowed values include: node-server, cloudflare-module, vercel
# See: https://nitro.build/deploy
# NITRO_PRESET=

# Bind address for the built Node server (defaults to 0.0.0.0).
# HOST=0.0.0.0

# Postgres pool size. Defaults to 2.
# DATABASE_MAX_CONNECTIONS=2

# Logging. LOG_LEVEL: trace | debug | info | warn | error | fatal
# LOG_LEVEL=info
# SERVER_DEBUG=false
# KYSELY_QUERY_DEBUG=false

# Enable response compression for /api/rpc when set (any value).
# RPC_COMPRESSION=1

# Shared secret for cron / scheduled task endpoints.
# CRON_SECRET=

# =============================================================================
# Optional: OAuth providers
# =============================================================================
# In each OAuth app, set the callback URI to:
#   http://localhost:3000/api/auth/callback/<provider>
# e.g. http://localhost:3000/api/auth/callback/github

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Toggle the buttons in the UI. Server-side env decides whether the flow works.
VITE_AUTH_GITHUB_ENABLED=true
VITE_AUTH_GOOGLE_ENABLED=false

# =============================================================================
# Optional: S3 file uploads (better-upload)
# =============================================================================

S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=
S3_URL=
